{
	"name": "bigmotor_lang",
	"version": "1.1.0",
	"description": "Bigmotor language compiler and interpreter (Brainfuck derivative)",
	"type": "module",
	"license": "WTFPL",
	"files": [
		"dist"
	],
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"bin": {
		"bigmotor": "dist/bin/bigmotor.js",
		"bigmotor-compile": "dist/bin/bmc.js",
		"bmr": "dist/bin/bigmotor.js",
		"bmc": "dist/bin/bmc.js"
	},
	"scripts": {
		"build": "tsup",
		"prepublishOnly": "npm run build",
		"format": "biome format --write src",
		"lint": "biome lint src",
		"check": "biome check --write src",
		"bigmotor": "tsx src/bin/interpreter.ts",
		"bmc": "tsx src/bin/compiler.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^20",
		"tsup": "^8.5.1",
		"tsx": "^4.19.2",
		"typescript": "^5"
	},
	"dependencies": {
		"zod": "^4.3.6"
	},
	"keywords": [
		"bigmotor",
		"brainfuck",
		"esolang",
		"interpreter",
		"compiler"
	]
}
